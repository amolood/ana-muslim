<?xml version="1.0" encoding="utf-8"?>
<!-- Base layout used on Android < 12 (API < 31).
     No custom @font/ reference here — android:fontFamily="@font/..." is not
     supported in RemoteViews before API 31 and causes InflateException.
     The API 31+ version in layout-v31/quran_widget.xml adds the Uthmanic font. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <!-- Teal top accent bar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#11D4B4" />

    <!-- Main content -->
    <LinearLayout
        android:id="@+id/widget_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical">

        <!-- Header row: "آية اليوم" label -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="✦  آية اليوم"
                android:textColor="#11D4B4"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_brand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المسلم"
                android:textColor="#33B2EFEB"
                android:textSize="10sp" />

        </LinearLayout>

        <!-- Divider -->
        <TextView
            android:id="@+id/widget_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:text=""
            android:background="#1A11D4B4"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="10dp" />

        <!-- Verse text — system Arabic font (no custom font on pre-API 31) -->
        <TextView
            android:id="@+id/widget_verse"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="#F0FFFFFF"
            android:textSize="22sp"
            android:lineSpacingMultiplier="1.2"
            android:maxLines="4"
            android:ellipsize="end"
            android:text="بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ" />

        <!-- Reference -->
        <TextView
            android:id="@+id/widget_ref"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:textColor="#9AE8E3"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="سورة الفاتحة ﴿١﴾" />

    </LinearLayout>

</LinearLayout>

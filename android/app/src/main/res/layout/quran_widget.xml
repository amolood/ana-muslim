<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1F1B">

    <!-- Teal top accent bar -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:text=""
        android:background="#11D4B4" />

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical">

        <!-- Header row: "آية اليوم" label -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layoutDirection="rtl">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="✦  آية اليوم"
                android:textColor="#11D4B4"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المسلم"
                android:textColor="#33B2EFEB"
                android:textSize="10sp" />

        </LinearLayout>

        <!-- Divider -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:text=""
            android:background="#1A11D4B4"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="10dp" />

        <!-- Verse text -->
        <TextView
            android:id="@+id/widget_verse"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="#F0FFFFFF"
            android:textSize="16sp"
            android:fontFamily="serif"
            android:lineSpacingMultiplier="1.6"
            android:maxLines="3"
            android:ellipsize="end"
            android:textDirection="rtl"
            android:layoutDirection="rtl"
            android:text="بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ" />

        <!-- Reference -->
        <TextView
            android:id="@+id/widget_ref"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:textColor="#9AE8E3"
            android:textSize="11sp"
            android:fontFamily="@font/kfgqpc_uthmanic_script"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:ellipsize="end"
            android:textDirection="rtl"
            android:text="سورة الفاتحة ﴿١﴾" />

    </LinearLayout>

</LinearLayout>

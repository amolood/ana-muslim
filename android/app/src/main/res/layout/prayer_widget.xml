<?xml version="1.0" encoding="utf-8"?>
<!-- Prayer times widget: shows all 5 daily prayers with customizable styling.
     Background is a tintable shape layer; decor overlay is optional. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@android:color/transparent"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToOutline="true">

    <!-- Background + Decor overlay container -->
    <FrameLayout
        android:id="@+id/bgContainer"
        android:background="@android:color/transparent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToOutline="true">

        <ImageView
            android:id="@+id/widgetBackgroundLayer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:clipToOutline="true" />

        <ImageView
            android:id="@+id/decorImage"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:clipToOutline="true" />
    </FrameLayout>

    <!-- Prayer times content: 5 columns -->
    <LinearLayout
        android:id="@+id/widget_root"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@android:color/transparent"
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Fajr -->
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <TextView
                android:id="@+id/fajr_title"
                android:textSize="16sp"
                android:textColor="#FFAAAAAA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الفجر" />
            <TextView
                android:id="@+id/fajr"
                android:textSize="16sp"
                android:textColor="#FFFFFFFF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="٠٥:٠٠" />
        </LinearLayout>

        <!-- Dhuhr -->
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <TextView
                android:id="@+id/dhuhr_title"
                android:textSize="16sp"
                android:textColor="#FFAAAAAA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الظهر" />
            <TextView
                android:id="@+id/dhuhr"
                android:textSize="16sp"
                android:textColor="#FFFFFFFF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="١٢:٠٠" />
        </LinearLayout>

        <!-- Asr -->
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <TextView
                android:id="@+id/asr_title"
                android:textSize="16sp"
                android:textColor="#FFAAAAAA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="العصر" />
            <TextView
                android:id="@+id/asr"
                android:textSize="16sp"
                android:textColor="#FFFFFFFF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="١٥:٠٠" />
        </LinearLayout>

        <!-- Maghrib -->
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <TextView
                android:id="@+id/maghrib_title"
                android:textSize="16sp"
                android:textColor="#FFAAAAAA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المغرب" />
            <TextView
                android:id="@+id/maghrib"
                android:textSize="16sp"
                android:textColor="#FFFFFFFF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="١٨:٠٠" />
        </LinearLayout>

        <!-- Isha -->
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <TextView
                android:id="@+id/isha_title"
                android:textSize="16sp"
                android:textColor="#FFAAAAAA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="العشاء" />
            <TextView
                android:id="@+id/isha"
                android:textSize="16sp"
                android:textColor="#FFFFFFFF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="١٩:٣٠" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<!-- Prayer times widget — all text is rendered as Bitmap on ImageViews
     to support custom Arabic fonts in RemoteViews (same approach as com.ayman.widget). -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@android:color/transparent"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:clipToOutline="true">

    <!-- Background + Decor overlay container -->
    <FrameLayout
        android:id="@+id/bgContainer"
        android:background="@android:color/transparent"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:clipToOutline="true">

        <ImageView
            android:id="@+id/widgetBackgroundLayer"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:scaleType="fitXY"
            android:clipToOutline="true" />

        <ImageView
            android:id="@+id/decorImage"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:scaleType="centerCrop"
            android:clipToOutline="true" />
    </FrameLayout>

    <!-- Main content -->
    <LinearLayout
        android:id="@+id/widget_root"
        android:gravity="center"
        android:orientation="vertical"
        android:background="@android:color/transparent"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layoutDirection="rtl">

        <!-- 5 Prayer columns -->
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">

            <!-- Fajr -->
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:id="@+id/fajr_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="@null" />
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/next_prayer_indicator_fajr"
                        android:visibility="gone"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:src="@drawable/ic_circle"
                        android:layout_marginEnd="4dp" />
                    <ImageView
                        android:id="@+id/fajr"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="@null" />
                </LinearLayout>
            </LinearLayout>

            <!-- Dhuhr -->
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:id="@+id/dhuhr_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="@null" />
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/next_prayer_indicator_dhuhr"
                        android:visibility="gone"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:src="@drawable/ic_circle"
                        android:layout_marginEnd="4dp" />
                    <ImageView
                        android:id="@+id/dhuhr"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="@null" />
                </LinearLayout>
            </LinearLayout>

            <!-- Asr -->
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:id="@+id/asr_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="@null" />
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/next_prayer_indicator_asr"
                        android:visibility="gone"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:src="@drawable/ic_circle"
                        android:layout_marginEnd="4dp" />
                    <ImageView
                        android:id="@+id/asr"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="@null" />
                </LinearLayout>
            </LinearLayout>

            <!-- Maghrib -->
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:id="@+id/maghrib_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="@null" />
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/next_prayer_indicator_maghrib"
                        android:visibility="gone"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:src="@drawable/ic_circle"
                        android:layout_marginEnd="4dp" />
                    <ImageView
                        android:id="@+id/maghrib"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="@null" />
                </LinearLayout>
            </LinearLayout>

            <!-- Isha -->
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:id="@+id/isha_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="@null" />
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/next_prayer_indicator_isha"
                        android:visibility="gone"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:src="@drawable/ic_circle"
                        android:layout_marginEnd="4dp" />
                    <ImageView
                        android:id="@+id/isha"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="@null" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- Countdown row (hidden when no next prayer) -->
        <LinearLayout
            android:id="@+id/nextPrayerCountdownContainer"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layoutDirection="rtl">
            <ImageView
                android:id="@+id/remainingTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@null" />
            <ImageView
                android:id="@+id/countdownText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@null" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>

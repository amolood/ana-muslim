                ],
                stops: const [0.3, 0.7, 1.0],
              ),
            ),
            child: AnimatedBuilder(
              animation: _pulseAnim,
              builder: (_, child) => Transform.scale(
                scale: 1 + (_pulseAnim.value * 0.12),
                child: child,
              ),
              child: Container(
                padding: const EdgeInsets.all(30),
                decoration: BoxDecoration(
                  shape: BoxShape.circle,
                  color: _guidanceColor.withValues(alpha: 0.15),
                  border: Border.all(
                    color: _guidanceColor.withValues(alpha: 0.4),
                    width: 3,
                  ),
                ),
                child: Icon(icon, size: 100, color: _guidanceColor),
              ),
            ),
          ),
          const SizedBox(height: 24),
          // Main guidance text
          Text(
            _guidanceText,
            style: GoogleFonts.tajawal(
              fontSize: 32,
              fontWeight: FontWeight.w900,
              color: colors.textPrimary,
              height: 1.2,
            ),
            textAlign: TextAlign.center,
          ),
          const SizedBox(height: 12),
          // Secondary instruction
          Container(
            padding: const EdgeInsets.symmetric(horizontal: 20, vertical: 10),
            decoration: BoxDecoration(
              color: isDark ? Colors.white.withValues(alpha: 0.05) : AppColors.primary.withValues(alpha: 0.08),
              borderRadius: BorderRadius.circular(12),
            ),
            child: Text(
              'حرّك الجوال ببطء حتى تظهر الكعبة',
              style: GoogleFonts.tajawal(
                fontSize: 14,
                color: colors.textSecondary,
                fontWeight: FontWeight.w600,
              ),
              textAlign: TextAlign.center,
            ),
          ),
          const SizedBox(height: 24),
          // Enhanced progress bar
          Container(
            padding: const EdgeInsets.all(4),
            decoration: BoxDecoration(
              borderRadius: BorderRadius.circular(16),
              gradient: LinearGradient(
                colors: [
                  _guidanceColor.withValues(alpha: 0.15),
                  _guidanceColor.withValues(alpha: 0.05),
                ],
              ),
            ),
            child: ClipRRect(
              borderRadius: BorderRadius.circular(12),
              child: Stack(
                children: [
                  Container(
                    height: 12,
                    decoration: BoxDecoration(
                      color: isDark ? Colors.white.withValues(alpha: 0.08) : colors.surfaceVariant,
                      borderRadius: BorderRadius.circular(12),
                    ),
                  ),
                  FractionallySizedBox(
                    widthFactor: _alignmentProgress,
                    child: Container(
                      height: 12,
                      decoration: BoxDecoration(
                        gradient: LinearGradient(
                          colors: [
                            _guidanceColor,
                            _guidanceColor.withValues(alpha: 0.8),
                          ],
                        ),
                        borderRadius: BorderRadius.circular(12),
                        boxShadow: [
                          BoxShadow(
                            color: _guidanceColor.withValues(alpha: 0.3),
                            blurRadius: 8,
                            offset: const Offset(0, 2),
                          ),
                        ],
                      ),
                    ),
                  ),
                ],
              ),
            ),
          ),
          const SizedBox(height: 12),
          // Progress percentage
          Text(
            '${(_alignmentProgress * 100).toInt()}%',
            style: GoogleFonts.tajawal(
              fontSize: 16,
              fontWeight: FontWeight.w700,
              color: _guidanceColor,
            ),
          ),
        ],
      ),
    );
  }

